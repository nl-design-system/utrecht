        "$value": "{utrecht.color.blue.90}"
      },
      "background-image": {
        "$value": "none"
      },
      "background-size": {
        "$value": "auto"
      },
      "color": {
        "$value": "{utrecht.color.black}"
      },
      "border-radius": {
        "$value": "{utrecht.border-radius.none}"
