          "$value": "\"○\""
        },
        "marker": {
          "font-size": {
            "$value": "{utrecht.typography.scale.md.font-size}"
          }
        }
      },
      "level-3": {
        "list-style-type": {
          "$value": "\"◆\""
        },
        "marker": {
          "font-size": {
            "$value": "{utrecht.typography.scale.md.font-size}"
          }
        }
      },
      "level-4": {
        "list-style-type": {
          "$value": "\"◇\""
        },
        "marker": {
          "font-size": {
            "$value": "{utrecht.typography.scale.md.font-size}"
          }
        }
      },
      "level-5": {
        "list-style-type": {
          "$value": "\"■\""
        },
        "marker": {
          "font-size": {
            "$value": "{utrecht.typography.scale.md.font-size}"
          }
        }
      },
      "level-6": {
        "list-style-type": {
          "$value": "\"□\""
        },
        "marker": {
          "font-size": {
            "$value": "{utrecht.typography.scale.md.font-size}"
          }
        }
      },
      "level-7": {
        "list-style-type": {
          "$value": "\"▲\""
        },
        "marker": {
          "font-size": {
            "$value": "0.75rem"
          }
        }
      },
      "level-8": {
        "list-style-type": {
          "$value": "\"△\""
        },
        "marker": {
          "font-size": {
            "$value": "0.75rem"
          }
        }
      }
    }
