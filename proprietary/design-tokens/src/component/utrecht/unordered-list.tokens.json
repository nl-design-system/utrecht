{
  "utrecht": {
    "unordered-list": {
      "padding-inline-start": {
        "$value": "0"
      },
      "margin-block-start": {
        "$value": "{utrecht.space.block.md}"
      },
      "margin-inline-start": {
        "$value": "{utrecht.space.text.md}"
      },
      "margin-block-end": {
        "$value": "0"
      },
      "font-size": {
        "$value": "{utrecht.typography.scale.md.font-size}"
      },
      "line-height": {
        "$value": "{utrecht.typography.line-height.md}"
      },
      "nested": {
