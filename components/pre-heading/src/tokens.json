{
  "utrecht": {
    "pre-heading": {
      "color": {
        "$extensions": {
          "nl.nldesignsystem.css-property-syntax": "<color>",
          "nl.nldesignsystem.fallback": ["utrecht.document.color"],
          "nl.nldesignsystem.figma-implementation": true
        },
        "$type": "color"
      },
      "font-family": {
        "$extensions": {
          "nl.nldesignsystem.css-property-syntax": "*",
          "nl.nldesignsystem.fallback": ["utrecht.document.font-family"],
          "nl.nldesignsystem.figma-implementation": true
        },
        "$type": "fontFamily"
      },
      "font-size": {
        "$extensions": {
          "nl.nldesignsystem.css-property-syntax": "<length>",
          "nl.nldesignsystem.figma-implementation": true
        },
        "$type": "dimension"
      },
      "font-weight": {
        "$extensions": {
          "nl.nldesignsystem.css-property-syntax": "<number>",
          "nl.nldesignsystem.figma-implementation": true
        },
        "$type": "fontWeight"
      },
      "line-height": {
        "$extensions": {
          "nl.nldesignsystem.css-property-syntax": "<length-percentage>",
          "nl.nldesignsystem.figma-implementation": true
        },
        "$type": "dimension"
      },
      "margin-block-end": {
        "$extensions": {
          "nl.nldesignsystem.css-property-syntax": "<length>",
          "nl.nldesignsystem.figma-implementation": false
        },
        "$type": "dimension"
      },
      "margin-block-start": {
        "$extensions": {
          "nl.nldesignsystem.css-property-syntax": "<length>",
          "nl.nldesignsystem.figma-implementation": false
        },
        "$type": "dimension"
      }
    }
  }
}
