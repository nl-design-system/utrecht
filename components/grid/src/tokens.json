{
  "utrecht": {
    "grid": {
      "spacing": {
        "sm": {
          "$extensions": {
            "nl.nldesignsystem.css-property-syntax": "<length>",
            "nl.nldesignsystem.figma-implementation": false
          },
          "$type": "dimension",
          "value": "8px",
          "comment": "Small spacing between grid cells"
        },
        "md": {
          "$extensions": {
            "nl.nldesignsystem.css-property-syntax": "<length>",
            "nl.nldesignsystem.figma-implementation": false
          },
          "$type": "dimension",
          "value": "16px",
          "comment": "Medium spacing between grid cells"
        },
        "lg": {
          "$extensions": {
            "nl.nldesignsystem.css-property-syntax": "<length>",
            "nl.nldesignsystem.figma-implementation": false
          },
          "$type": "dimension",
          "value": "24px",
          "comment": "Large spacing between grid cells"
        }
      },
      "columns": {
        "total": {
          "$extensions": {
            "nl.nldesignsystem.css-property-syntax": "<number>",
            "nl.nldesignsystem.figma-implementation": false
          },
          "$type": "other",
          "value": "12",
          "comment": "Total number of columns in the grid system"
        },
        "default": {
          "$extensions": {
            "nl.nldesignsystem.css-property-syntax": "<number>",
            "nl.nldesignsystem.figma-implementation": false
          },
          "$type": "other",
          "value": "4",
          "comment": "Default column span when no size is specified"
        }
      }
    }
  }
}
